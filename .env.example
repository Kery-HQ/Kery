# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://kery:kery@localhost:19832/kery

# ─── LLM keys (at least one required) ────────────────────────────────────────
# OPENROUTER_API_KEY unlocks all catalog models via OpenRouter.
# Without it, set the provider key that matches each model (OpenAI / Anthropic / Gemini).
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ─── Model configuration (defaults shown) ────────────────────────────────────
# Agent: vision + reasoning for browser automation steps
AGENT_MODEL=openai/gpt-4.1-mini
# Summary: cheap text for run summaries
SUMMARY_MODEL=gemini-2.5-flash-lite
# Review Agent + Path Generator: cheap vision/reasoning
REVIEW_MODEL=gemini-2.5-flash-lite
# Per-step Review Agent + filmstrip journey review (vision, via OpenRouter)
REVIEW_AGENT_MODEL=gemini-2.5-flash
# Script/strategy generation
SCRIPT_MODEL=gemini-2.5-flash

# ─── Stagehand (optional) ────────────────────────────────────────────────────
STAGEHAND_ENABLED=true
STAGEHAND_MODEL=google/gemini-2.0-flash

# ─── Security ──────────────────────────────────────────────────────────────────
# Optional: AES-256-GCM key for encrypting stored credentials (64 hex chars / 32 bytes).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# When unset, credentials are stored in plaintext (backwards compatible).
# ENCRYPTION_KEY=

# ─── Redis (required for run queue) ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=19833
APP_URL=http://localhost:19834
RUN_TIMEOUT_MINUTES=15
