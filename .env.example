# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://kery:kery@localhost:5432/kery

# ─── LLM keys (at least one required) ────────────────────────────────────────
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ─── Model configuration (defaults shown) ────────────────────────────────────
# Agent: vision + reasoning for browser automation steps
GEMINI_AGENT_MODEL=openai/gpt-4o-mini
# Summary: cheap text for run summaries
GEMINI_SUMMARY_MODEL=gemini-2.5-flash-lite
# Review Agent + Path Generator: cheap vision/reasoning
GEMINI_REVIEW_MODEL=gemini-2.5-flash-lite
# Review Agent model (vision + reasoning, via OpenRouter)
REVIEW_AGENT_MODEL=anthropic/claude-sonnet-4.6
# Script/strategy generation
GEMINI_SCRIPT_MODEL=gemini-2.5-flash

# ─── Stagehand (optional) ────────────────────────────────────────────────────
STAGEHAND_ENABLED=true
STAGEHAND_MODEL=google/gemini-2.0-flash

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
APP_URL=http://localhost:5173
RUN_TIMEOUT_MINUTES=15
