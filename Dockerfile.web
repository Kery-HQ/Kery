# Build stage — same workspace layout as root package.json (no source until install)
FROM node:20-alpine AS build
WORKDIR /app

COPY package.json package-lock.json* ./
COPY packages/engine/package.json packages/engine/
COPY packages/db/package.json packages/db/
COPY packages/client/package.json packages/client/
COPY packages/mcp/package.json packages/mcp/
COPY apps/api/package.json apps/api/
COPY apps/web/package.json apps/web/

# Skip root postinstall (build:libs) — no TS sources copied yet
RUN npm install --ignore-scripts --workspaces --include-workspace-root

COPY apps/web/ apps/web/

ARG VITE_API_BASE_URL=
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL

RUN npm run build --workspace=@kery/web

# Serve stage
FROM nginx:alpine
COPY --from=build /app/apps/web/dist /usr/share/nginx/html
COPY apps/web/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
